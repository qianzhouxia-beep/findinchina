# ============================================
# FindInChina 环境变量配置
# ============================================
# 复制此文件为 .env.local，然后填入真实值

# ---- Supabase ----
# URL 格式：https://<project-ref>.supabase.co
# 找法：Supabase Dashboard → 顶部 "Connect" 按钮 → Project URL
# 或：Settings → General → Project URL
NEXT_PUBLIC_SUPABASE_URL=https://gmzqogzqseylgxcomlgz.supabase.co

# Publishable key（旧版叫 anon public key）
# 找法：Settings → API Keys → Publishable key
# 2026 新版格式：sb_publishable_xxxxx
# 旧版格式：eyJxxxxx（也兼容）
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_GtuPmbaa1T_MlmRd-dW4Pg_zYY9f161

# Secret key（旧版叫 service_role key）
# 找法：Settings → API Keys → Secret keys（需要点眼睛图标显示）
# 2026 新版格式：sb_secret_xxxxx
SUPABASE_SERVICE_ROLE_KEY=sb_secret_A-fvv...你的完整key...

# ---- AI API: DeepSeek（推荐，便宜 + 中文强 + 新用户免费）----
# 申请：https://platform.deepseek.com → API Keys
DEEPSEEK_API_KEY=sk-你的key

# ---- Newsletter (Beehiiv，可选) ----
BEEHIIV_API_KEY=
BEEHIIV_PUBLICATION_ID=

# ---- Stripe（可选，后期） ----
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# ---- Analytics ----
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=

# ---- Email ----
RESEND_API_KEY=